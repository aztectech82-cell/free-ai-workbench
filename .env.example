# Free AI Workbench - local config
# Copy this to .env.local and fill in what you need.
# Nothing here is required for free/local mode.

OLLAMA_URL=http://localhost:11434
DEFAULT_LOCAL_MODEL=deepseek-r1:8b
WORKSPACE_DIR=./workspace

# Optional paid API keys - leave blank to run 100% free on local models
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
